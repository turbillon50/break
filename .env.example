# =============================================================================
# Break Memory — environment variables
# =============================================================================
# Copy to .env for local dev. In production these are configured in Railway UI.
# =============================================================================

# Neon Postgres connection string for Break's own database.
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# REQUIRED. Server refuses to start without it.
DATABASE_URL_BREAK=

# Neon Postgres readonly connection string for Tanit's database.
# Used only by /api/tanit-context/* endpoints.
# OPTIONAL. If empty, those endpoints return 503 with a clear message;
# the rest of the server runs normally.
DATABASE_URL_TANIT_READONLY=

# Shared secret required on POST/PATCH/DELETE under /api/break/*.
# Generate with: openssl rand -hex 32
# REQUIRED in production. In dev, can be any string.
BREAK_WRITE_TOKEN=

# HTTP port. Railway injects $PORT automatically; locally defaults to 8080.
PORT=8080

# Runtime mode. Use "production" in Railway, "development" locally.
NODE_ENV=development

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
